// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReviewStatus {
  pending
  verified
  rejected
  archived
}

enum ShelterType {
  government
  ngo
  municipality
  civilian
  hotel
}

enum ReportType {
  shelter_status
  threat
  damage
  general
}

enum AlertSeverity {
  urgent
  warning
  info
}

enum AuditAction {
  create
  update
  verify
  reject
  archive
  publish
}

model Shelter {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  type           ShelterType
  nameAr         String
  nameLb         String?
  addressAr      String?
  governorateAr  String?
  districtAr     String?

  latitude       Float
  longitude      Float

  capacityTotal  Int?
  capacityUsed   Int?
  statusTextAr   String?
  statusTextLb   String?

  contactPhone   String?
  contactWhatsApp String?
  contactTelegram String?

  sourceName     String?
  sourceUrl      String?
  lastSourceSync DateTime?

  reviewStatus   ReviewStatus @default(verified)

  reports        Report[]
}

model Report {
  id            String       @id @default(cuid())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  type          ReportType
  titleAr       String
  titleLb       String?
  descriptionAr String?
  descriptionLb String?

  latitude      Float?
  longitude     Float?
  occursAt      DateTime?

  shelterId     String?
  shelter       Shelter?     @relation(fields: [shelterId], references: [id], onDelete: SetNull)

  reviewStatus  ReviewStatus @default(pending)
  reviewedAt    DateTime?
  reviewedBy    String?
  reviewNote    String?

  source        String?      // "web" | "telegram" | "whatsapp" | ... (MVP)
  evidenceUrl   String?
}

model Alert {
  id            String        @id @default(cuid())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  titleAr       String
  titleLb       String?
  bodyAr        String
  bodyLb        String?

  severity      AlertSeverity @default(warning)
  latitude      Float?
  longitude     Float?
  radiusMeters  Int?
  startsAt      DateTime?
  endsAt        DateTime?

  reviewStatus  ReviewStatus  @default(pending)
  publishedAt   DateTime?
  publishedBy   String?
}

model AreaSubscription {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  areaNameAr  String
  areaNameLb  String?

  // MVP: a simple bounding circle. Later: polygon geometry.
  latitude    Float
  longitude   Float
  radiusMeters Int

  // Web Push subscription JSON (encrypted payload) - stored as string for MVP.
  webPushSubscriptionJson String?

  // Telegram placeholders
  telegramChatId String?

  // Basic anti-abuse + rotation
  isActive   Boolean  @default(true)
}

model AuditLog {
  id          String      @id @default(cuid())
  createdAt   DateTime    @default(now())
  action      AuditAction
  entityType  String
  entityId    String
  actor       String?
  metaJson    String?
}

model Hotline {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  nameAr      String
  phone       String
  region      String   @default("Lebanon")
  category    String   // emergency, medical, police, etc.
  notes       String?
  sourceUrl   String?
  isActive    Boolean  @default(true)
  displayOrder Int     @default(0)
}
